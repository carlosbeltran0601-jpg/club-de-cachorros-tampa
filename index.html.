<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Club de Cachorros - Tampa, FL</title>
    <style>
        :root {
            --gold: #c5a059;
            --black: #1a1a1a;
            --cream: #fdfaf5;
            --white: #ffffff;
        }

        body {
            font-family: 'Times New Roman', Times, serif;
            margin: 0;
            background-color: var(--cream);
            color: var(--black);
        }

        /* Top Navigation */
        .header-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 5%;
            background: white;
            border-bottom: 2px solid var(--gold);
        }

        .lang-select {
            padding: 5px 10px;
            border: 1px solid var(--gold);
            border-radius: 20px;
            cursor: pointer;
        }

        /* Hero Section with People/Dog Background */
        .hero {
            position: relative;
            background: linear-gradient(rgba(255,255,255,0.6), rgba(255,255,255,0.6)), 
                        url('https://images.unsplash.com/photo-1554456854-55a063e97cb4?auto=format&fit=crop&q=80&w=2070');
            background-size: cover;
            background-position: center;
            padding: 80px 20px;
            text-align: center;
        }

        .main-card {
            max-width: 800px;
            width: 95%;
            border-radius: 15px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            margin-bottom: 20px;
            border: 5px solid white;
        }

        /* Testimonials Section */
        .reviews {
            padding: 60px 5%;
            text-align: center;
            background: white;
        }

        .review-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 40px;
        }

        .review-card {
            background: var(--cream);
            padding: 25px;
            border-radius: 10px;
            border: 1px solid #eee;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .stars { color: var(--gold); margin-bottom: 10px; font-size: 1.2rem; }

        /* Footer */
        footer {
            background: var(--black);
            color: white;
            padding: 50px 20px;
            text-align: center;
        }

        .phone-link {
            color: var(--gold);
            font-size: 2.5rem;
            text-decoration: none;
            font-weight: bold;
            display: block;
            margin: 15px 0;
        }

        .en-text { display: none; }
    </style>
</head>
<body>

<div class="header-nav">
    <div style="font-weight: bold; letter-spacing: 2px;">CLUB DE CACHORROS</div>
    <select class="lang-select" onchange="changeLang(this.value)">
        <option value="es">Español 🇪🇸</option>
        <option value="en">English 🇺🇸</option>
    </select>
</div>

<section class="hero">
    <img src="DF3EE4A4-5740-4788-8960-0D5333BABDAB.png" alt="Club de Cachorros" class="main-card">
    
    <h1 class="es-text">Cachorros Felices, Familias Felices</h1>
    <h1 class="en-text">Happy Puppies, Happy Families</h1>
</section>

<section class="reviews">
    <h2 class="es-text">Testimonios de Clientes</h2>
    <h2 class="en-text">Customer Reviews</h2>
    
    <div class="review-grid">
        <div class="review-card">
            <div class="stars">★★★★★</div>
            <p class="es-text">"Nuestra pequeña Luna ha traído tanta felicidad. ¡Gracias!"</p>
            <p class="en-text">"Our little Luna has brought so much happiness. Thank you!"</p>
            <strong>- Familia Perez</strong>
        </div>
        <div class="review-card">
            <div class="stars">★★★★★</div>
            <p class="es-text">"El cuidado y la profesionalidad son increíbles. Súper recomendados."</p>
            <p class="en-text">"The care and professionalism are incredible. Highly recommended."</p>
            <strong>- Carlos M.</strong>
        </div>
        <div class="review-card">
            <div class="stars">★★★★★</div>
            <p class="es-text">"Una experiencia maravillosa. El criadero es impecable."</p>
            <p class="en-text">"A wonderful experience. The kennel is impeccable."</p>
            <strong>- Ana L.</strong>
        </div>
        <div class="review-card">
            <div class="stars">★★★★★</div>
            <p class="es-text">"Encontramos a nuestro mejor amigo aquí. Muy sano y juguetón."</p>
            <p class="en-text">"We found our best friend here. Very healthy and playful."</p>
            <strong>- The Thompsons</strong>
        </div>
        <div class="review-card">
            <div class="stars">★★★★★</div>
            <p class="es-text">"Excelente servicio de principio a fin. El veterinario quedó impresionado."</p>
            <p class="en-text">"Excellent service from start to finish. Our vet was impressed."</p>
            <strong>- Jessica K.</strong>
        </div>
    </div>
</section>

<footer>
    <p class="es-text">¿Listo para conocer a tu nuevo mejor amigo? Llámanos hoy:</p>
    <p class="en-text">Ready to meet your new best friend? Call us today:</p>
    <a href="tel:8632770168" class="phone-link">863-277-0168</a>
    <p>Tampa, FL | @clubdecachorros</p>
</footer>

<script>
    function changeLang(lang) {
        const es = document.querySelectorAll('.es-text');
        const en = document.querySelectorAll('.en-text');
        if (lang === 'en') {
            es.forEach(el => el.style.display = 'none');
            en.forEach(el => el.style.display = 'block');
        } else {
            es.forEach(el => el.style.display = 'block');
            en.forEach(el => el.style.display = 'none');
        }
    }
</script>

</body>
</html>
